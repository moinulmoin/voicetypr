{
  "name": "voicetypr",
  "private": true,
  "version": "2.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "ci:mac": "bash ./scripts/ci-local-macos.sh",
    "ci:win": "powershell -ExecutionPolicy Bypass -File .\\scripts\\ci-local-windows.ps1",
    "ci:win:full": "powershell -ExecutionPolicy Bypass -File .\\scripts\\ci-local-windows.ps1 -Full",
    "sidecar:ensure-ffmpeg": "node scripts/ensure-ffmpeg-sidecar.cjs",
    "sidecar:build": "bash ./scripts/build-parakeet-sidecar.sh",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node scripts/dev-tauri.cjs",
    "windows:store:msix": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-msix-store.ps1",
    "windows:store:stage": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-msix-store.ps1 -NoPack",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:backend": "cd src-tauri && cargo test",
    "test:frontend": "vitest run",
    "test:all": "pnpm test:backend && pnpm test:frontend",
    "quality-gate": "./scripts/quality-gate-check.sh",
    "benchmark": "node scripts/benchmark-runner.js",
    "macos:sign": "./scripts/macos-sign-app.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.3.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-os": "^2.3.0",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-shell": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "radix-ui": "1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tauri-plugin-macos-permissions-api": "^2.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.6",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.1.1",
    "shadcn": "^4.7.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
