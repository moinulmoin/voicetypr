{
  "$schema": "https://schema.tauri.app/config/2",
  "_comment": "Windows x86_64 release config only. Bundles the x64 Vulkan sidecar; do not use for Windows ARM64 CPU-only builds.",
  "bundle": {
    "resources": [
      "windows/resources/vc_redist.x64.exe",
      "windows/resources/VulkanRT-Installer.exe"
    ],
    "externalBin": [
      "../sidecar/ffmpeg/dist/ffmpeg",
      "../sidecar/ffmpeg/dist/ffprobe",
      "../sidecar/ffmpeg/dist/ffmpeg.exe",
      "../sidecar/ffmpeg/dist/ffprobe.exe",
      "../sidecar/dist/formatting-sidecar",
      "../sidecar/whisper-vulkan/dist/whisper-vulkan-sidecar"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    }
  }
}
